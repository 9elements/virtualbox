/*/*: --svn-sync-process-export none
/tinderbox*: --svn-sync-process-export whatever

*.cgi:          --treat-as shell
*.conf.j2:      --treat-as hashtext --del-action force-native-eol --add-action force-lf
*.conf.orig:    --treat-as hashtext --del-action force-native-eol --add-action force-lf
*.conf:         --treat-as hashtext --del-action force-native-eol --add-action force-lf
*_conf:         --treat-as hashtext --del-action force-native-eol --add-action force-lf
*.cs:           --treat-as plaintext
*.css:          --treat-as h --no-fix-header-guards
*.deb:          --treat-as binary
*.eot:          --treat-as binary
*.fcgi:         --treat-as shell
*.htaccess:     --treat-as shell
*.htm:          --treat-as plaintext
*.ini:          --treat-as plaintext
*.js:           --treat-as h --no-fix-header-guards
*.msi:          --treat-as binary
*.ora:          --treat-as sql
*.pem:          --treat-as shell
*.php:          --treat-as c
*.po:           --treat-as shell
*.ps1-save.1:   --treat-as perl
*.ps1:          --treat-as perl
*.ps1_:         --treat-as perl
*.rpm:          --treat-as binary
*.rss:          --treat-as plaintext
*.sso:          --treat-as binary
*.svg:          --treat-as plaintext --dont-set-svn-eol --dont-set-svn-keywords --no-convert-eol --no-convert-tabs --no-strip-trailing-blanks
*.types:        --treat-as shell
*.TXT:          --treat-as plaintext
*.wbm:          --treat-as binary
*.wsgi:         --treat-as shell
*.xslt:         --treat-as xslt
*.xsd:          --treat-as xml
*/magic:        --treat-as shell

