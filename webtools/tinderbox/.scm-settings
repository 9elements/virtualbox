/client/*.cfg|/client/*.opt|/client/parfait-submit.sh|/client/copy-lnx64dep-docs.sh|/client/tindertux-quota.sh: \
        --svn-sync-process-export none

/sql/*: --external-copyright
/sql/partial-db-dump.sh: --no-external-copyright
/server/*: --external-copyright
/client/*.pl: --external-copyright
/client/*.cfg: --treat-as plaintext --dont-set-svn-keywords --add-action force-native-eol --external-copyright
/client/*.opt: --treat-as plaintext --dont-set-svn-keywords --add-action force-native-eol --external-copyright

