+    -no-eglfs \
+    -no-gif \
+    -no-glib \
+    -rpath \
+    -qt-libjpeg \
+    -qt-libpng \
+    -silent \
+    $SDK \
+    > $LOG_FILE 2>&1
+if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
