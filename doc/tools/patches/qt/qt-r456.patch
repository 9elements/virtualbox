--- vbox-make-package-darwin.sh	(nonexistent)
+++ vbox-make-package-darwin.sh	(revision 456)
@@ -0,0 +1,208 @@
+#!/bin/bash
+
+# Help function:
+Help()
+{
+    echo
+    echo "NAME"
+    echo "     vbox-make-package-darwin.sh"
+    echo
+    echo "SYNOPSIS"
+    echo "     vbox-make-package-darwin.sh [-h | -v]"
+    echo
+    echo "DESCRIPTION"
+    echo "     Packs a VirtulBox-compatible Qt tool for macOS."
+    echo
+    echo "     The options are as follows:"
+    echo "     -h (--help)          Prints this help."
+    echo "     -v (--verbose)       Requests verbose script output."
+    echo
+}
+
+# Setup:
+REVISION=`svn info|sed -e '/^Last Changed Rev/!d' -e 's/^Last Changed Rev: *\(.*\)/\1/'`
+VERSION=`svn info|sed -e '/^Relative URL/!d' -e 's/^Relative URL[^0-9.]*\(.*\)/\1/'`
+WORK_FOLDER=`pwd`
+OUTPUT_FOLDER=out
+INSTALL_FOLDER=staged-install
+INSTALL_FOLDER_FULL=$WORK_FOLDER/$INSTALL_FOLDER
+LOG_FILE=$WORK_FOLDER/vbox-install.log
+ARCH_NAME=$(uname -m | sed -e 's/x86_64/amd64/')
+
+# Validate:
+if [ -z "${VERSION}" ]; then
+    echo 'Cannot determine version!'
+    exit 1
+fi
+if [ -z "${REVISION}" ]; then
+    echo 'Cannot determine revision!'
+    exit 1
+fi
+if [ -z "${ARCH_NAME}" ]; then
+    echo 'Unable to determine architecture!'
+    exit 1
+fi
+
+# Handle arguments:
+while getopts ":vh-:" option; do
+    case $option in
+        -) # full names
+            case $OPTARG in
+                verbose) # request Verbose output
+                    LOG_FILE=/dev/stdout;;
+                help) # display Help
+                    Help
+                    exit 2;;
+                *) # invalid argument
+                    echo "Error: Illegal option"
+                    exit 2;;
+            esac;;
+        v) # request Verbose output
+            LOG_FILE=/dev/stdout;;
+        h) # display Help
+            Help
+            exit 2;;
+        *) # invalid argument
+            echo "Error: Illegal option"
+            exit 2;;
+    esac
+done
+
+# Install:
+cd $OUTPUT_FOLDER
+echo 'Installing ...'
+rm -Rf $INSTALL_FOLDER_FULL
+cmake --install . --prefix $INSTALL_FOLDER_FULL/Applications/VirtualBox.app/Contents > $LOG_FILE 2>&1
+if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+    echo '* make install failed, have a look at vbox-install.log for details! *'
+    exit 1
+fi
+cd $WORK_FOLDER
+
+# Save some space by removing some unused stuff:
+cd $INSTALL_FOLDER/Applications/VirtualBox.app/Contents
+for i in \
+    androiddeployqt androiddeployqt6 androidtestrunner Designer.app \
+    qml qmldom qmlformat qmllint qmlpreview qmlprofiler qmltc \
+    ; do
+    rm -r bin/$i
+done
+for i in \
+    androiddeployqt androidtestrunner Designer \
+    qml qmldom qmlformat qmllint qmlpreview qmlprofiler qmltc \
+    ; do
+    rm -r bin/$i.dSYM
+done
+for i in \
+    qmlcachegen qmlimportscanner qmltyperegistrar \
+    ; do
+    rm -r libexec/$i libexec/$i.dSYM
+done
+for i in \
+    qmltooling \
+    ; do
+    rm -r plugins/$i
+done
+for i in \
+    qml \
+    ; do
+    rm -r $i
+done
+for i in \
+    QtConcurrent QtDesigner QtDesignerComponents \
+    QtLabsFolderListModel QtLabsQmlModels QtLabsSettings \
+    QtQmlCompiler QtQmlCore QtQmlLocalStorage QtQmlModels QtQmlWorkerScript QtQmlXmlListModel \
+    QtScxml QtScxmlQml QtStateMachineQml QtTest \
+    ; do
+    rm -r `find . -name $i.framework*`
+done
+for i in \
+    DeviceDiscoverySupport ExampleIcons FbSupport PacketProtocol \
+    QmlDebug QmlDom QmlIntegration QmlTypeRegistrar \
+    ; do
+    rm -r include/Qt$i
+done
+for i in \
+    DeviceDiscoverySupport ExampleIcons FbSupport PacketProtocol \
+    QmlDebug QmlDom QmlTypeRegistrar \
+    ; do
+    rm -r `find . -name libQt6$i.*`
+done
+cd - > /dev/null
+
+# Generate patch:
+rm -f qt.patch
+echo 'Generating patch, please wait ...'
+BASEREV=`svn log -r 1:HEAD --limit 1 --stop-on-copy | sed -n -e '2s/^r\([0-9]\{1,\}\) .*$/\1/p'`
+svn diff \
+    --ignore-properties \
+    -r ${BASEREV}:HEAD \
+    > qt.patch
+if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+    echo '* svn diff failed!'
+    exit 1
+fi
+
+# Copy stuff:
+set -e
+cp -v readme.tool-darwin ./$INSTALL_FOLDER/Applications/VirtualBox.app/Contents/readme.tool >> $LOG_FILE 2>&1
+cp -v qt.patch ./$INSTALL_FOLDER/Applications/VirtualBox.app/Contents/ >> $LOG_FILE 2>&1
+set +e
+
+# Separate the dSYM information from the release binaries:
+echo 'Stripping dSYM related information ...'
+cd $INSTALL_FOLDER/Applications/VirtualBox.app/Contents/lib
+for f in `find . -type f -not -path "*dSYM*" -name \*VBox`; do
+  fnew="`dirname ${f}`/`basename $f`"
+# I don't really know whether this is required, but dsymutil says there is no dSYM related
+# information in those files anymore.  Maybe Qt guys finally made -separate-debug-info flag
+# work properly, but subsequent strip still wipes _something_...  I have tried to debug VBox
+# based on this tool/symbols and it seems kinda works, Qt part of stack being resolved
+# successfully, though not without warnings.
+# That's the old (disabled) part:
+# dsymutil -o "${fnew}.dSYM" "${fnew}" >> $LOG_FILE 2>&1
+  strip -Sxru "${fnew}" >> $LOG_FILE 2>&1
+done
+if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+    echo '* strip dsym failed, have a look at vbox-install.log for details! *'
+    exit 1
+fi
+cd - > /dev/null
+
+# Move the .dSYM directories into a separate directory, easier to tar
+echo 'Preparing tar packages ...'
+cd $INSTALL_FOLDER/Applications/VirtualBox.app/Contents/
+for f in `find . -name \*dSYM`; do
+    dir=debug/`dirname $f`
+    mkdir -p ../../../$dir
+    mv $f ../../../$dir
+done
+cd - > /dev/null
+
+# Tar it up:
+tar cjvf \
+    $INSTALL_FOLDER/darwin.${ARCH_NAME}.qt.v${VERSION}-r${REVISION}.tar.bz2 \
+    -C $INSTALL_FOLDER/Applications/VirtualBox.app/Contents/ . \
+    >> $LOG_FILE 2>&1
+if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+    echo '* tar failed, have a look at vbox-install.log for details!'
+    exit 1
+fi
+
+tar cjvf \
+    $INSTALL_FOLDER/darwin.${ARCH_NAME}.qt.dsym.v${VERSION}-r${REVISION}.tar.bz2 \
+    -C $INSTALL_FOLDER/debug . \
+    >> $LOG_FILE 2>&1
+if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+    echo '* tar/dsym failed, have a look at vbox-install.log for details!'
+    exit 1
+fi
+
+echo "darwin.${ARCH_NAME}.qt.v${VERSION}-r${REVISION}.tar.bz2_MD5  = `md5 -q $INSTALL_FOLDER/darwin.${ARCH_NAME}.qt.v${VERSION}-r${REVISION}.tar.bz2`"
+echo "darwin.${ARCH_NAME}.qt.v${VERSION}-r${REVISION}.tar.bz2_SIZE = `stat -f %z $INSTALL_FOLDER/darwin.${ARCH_NAME}.qt.v${VERSION}-r${REVISION}.tar.bz2`"
+
+echo "darwin.${ARCH_NAME}.qt.dsym.v${VERSION}-r${REVISION}.tar.bz2_MD5  = `md5 -q $INSTALL_FOLDER/darwin.${ARCH_NAME}.qt.dsym.v${VERSION}-r${REVISION}.tar.bz2`"
+echo "darwin.${ARCH_NAME}.qt.dsym.v${VERSION}-r${REVISION}.tar.bz2_SIZE = `stat -f %z $INSTALL_FOLDER/darwin.${ARCH_NAME}.qt.dsym.v${VERSION}-r${REVISION}.tar.bz2`"
+
+exit 0
+
