--- vbox-do-it-all.cmd	(nonexistent)
+++ vbox-do-it-all.cmd	(revision 456)
@@ -0,0 +1,106 @@
+@echo off
+setlocal
+
+goto startup
+:description
+echo(
+echo Performs [re]configuration, [re]building and [re]packing of VirtulBox-compatible Qt tool for Windows.
+echo   Usage:
+echo     vbox-do-it-all.cmd [cleanup] [verbose]
+echo   Options:
+echo     cleanup    refers to cleaning before building and is done when case-insensitive "cleanup" option is given.
+echo     verbose    refers to verbose script output and is done when case-insensitive "verbose" option is given.
+goto error_end
+
+:startup
+set MYPWD=%CD%
+for /f "tokens=*" %%d in ('cd') do set MYPWD=%%d
+if "%1"=="/?" goto description
+if not "%3"=="" goto description
+set loop_option_cleanup=1
+set loop_option_verbose=1
+set MYOUT_BUILD=out
+set MYOUT_BUILD_ARM=out-arm
+
+:loop_options
+if "%1"=="" goto loop_options_done
+    if /i defined loop_option_%1 goto case_%1
+    :case_unknown
+        echo Unknown option: %1
+        goto loop_options_break
+    :case_cleanup
+        set MYCLEANUP=%1
+        goto loop_options_break
+    :case_verbose
+        set MYVERBOSE=%1
+        goto loop_options_break
+    :loop_options_break
+    shift
+goto loop_options
+:loop_options_done
+
+:notify_start
+where /Q "send_notification.cmd" || cmd /c "exit /b 0" && goto notify_start_done
+call send_notification.cmd "%time%: Qt %MYQT_VERSION% build started ..."
+:notify_start_done
+
+:perform_cleanup
+if "%MYCLEANUP%"=="" goto perform_cleanup_done
+call vbox-clean-all.cmd %MYVERBOSE% || goto error_end
+:perform_cleanup_done
+
+:perform_configure
+if exist %MYOUT_BUILD%/vbox-configured goto perform_configure_done
+call vbox-configure.cmd %MYVERBOSE% || goto error_end
+echo done > %MYOUT_BUILD%/vbox-configured
+:perform_configure_done
+
+:perform_build
+if exist %MYOUT_BUILD%/vbox-built goto perform_build_done
+call vbox-build-all.cmd %MYVERBOSE% || goto error_end
+echo done > %MYOUT_BUILD%/vbox-built
+:perform_build_done
+
+:perform_install
+if exist %MYOUT_BUILD%/vbox-installed goto perform_install_done
+call vbox-make-package.cmd %MYVERBOSE% || goto error_end
+echo done > %MYOUT_BUILD%/vbox-installed
+:perform_install_done
+
+:perform_configure_arm
+if exist %MYOUT_BUILD_ARM%/vbox-configured-arm goto perform_configure_arm_done
+call vbox-configure-arm.cmd %MYVERBOSE% || goto error_end
+echo done > %MYOUT_BUILD_ARM%/vbox-configured-arm
+:perform_configure_arm_done
+
+:perform_build_arm
+if exist %MYOUT_BUILD_ARM%/vbox-built-arm goto perform_build_arm_done
+call vbox-build-all-arm.cmd %MYVERBOSE% || goto error_end
+echo done > %MYOUT_BUILD_ARM%/vbox-built-arm
+:perform_build_arm_done
+
+:perform_install_arm
+if exist %MYOUT_BUILD_ARM%/vbox-installed-arm goto perform_install_arm_done
+call vbox-make-package-arm.cmd %MYVERBOSE% || goto error_end
+echo done > %MYOUT_BUILD_ARM%/vbox-installed-arm
+:perform_install_arm_done
+
+:notify_finish
+where /Q "send_notification.cmd" || cmd /c "exit /b 0" && goto notify_finish_done
+call send_notification.cmd "%time%: Qt %MYQT_VERSION% build complete!"
+:notify_finish_done
+
+echo Package successfully prepared!
+goto end
+
+
+:error_end
+cd %MYPWD%
+endlocal
+exit /b 1
+
+:end
+cd %MYPWD%
+endlocal
+exit /b 0
+
