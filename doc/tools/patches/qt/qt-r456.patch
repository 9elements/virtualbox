Index: vbox-make-package.cmd
===================================================================
--- vbox-make-package.cmd	(nonexistent)
+++ vbox-make-package.cmd	(revision 456)
@@ -0,0 +1,129 @@
+@echo off
+setlocal
+
+goto startup
+:description
+echo(
+echo [Re]packs a VirtulBox-compatible Qt tool for Windows AMD64.
+echo Note: can be executed as a part of vbox-do-it-all.cmd call.
+echo   Usage:
+echo     vbox-make-package.cmd [verbose]
+echo   Options:
+echo     ?          shows this help.
+echo     verbose    refers to verbose script output and is done when case-insensitive "verbose" option is given.
+goto error_end
+
+:startup
+set MYPWD=%CD%
+for /f "tokens=*" %%d in ('cd') do set MYPWD=%%d
+set MYLOG_START="> %MYPWD%\vbox-install.log 2>&1"
+set MYLOG_APPEND=">> %MYPWD%\vbox-install.log 2>&1"
+if "%1"=="" goto startup_done
+if not "%2"=="" goto description
+if /i "%1"=="verbose" (set MYLOG_START= && set MYLOG_APPEND=) else (goto description)
+:startup_done
+
+:perform_setup
+if not "%MYQT_VERSION%"=="" goto perform_setup_done
+call vbox-env.cmd || goto error_end
+:perform_setup_done
+
+:perform_prepare
+echo Preparing package for AMD64 ...
+echo Out directory is: %MYOUT_BASE%
+echo Final directory is: %MYOUT_FINAL%
+:perform_prepare_done
+
+:cleanup_output
+if not exist %MYOUT_FINAL% goto cleanup_output_done
+echo Removing stale out directory: %MYOUT_FINAL%
+rmdir /S /Q %MYOUT_FINAL%
+if not %ERRORLEVEL%==0 goto error_general
+:cleanup_output_done
+
+:cleanup_packages
+if not exist %MYOUT_BASE%\win.amd64*.zip goto cleanup_packages_done
+echo Removing stale out packages inside: %MYOUT_BASE%
+del %MYOUT_BASE%\win.amd64*.zip
+if not %ERRORLEVEL%==0 goto error_general
+:cleanup_packages_done
+
+:perform_install_files
+cd %MYOUT_BUILD%
+echo Installing files into intermediate package directory: %MYOUT_BASE% ...
+%MYCONF_TOOL% --install . --prefix=%MYOUT_FINAL%^%MYLOG_START% 
+if not %ERRORLEVEL%==0 goto error_install
+cd %MYPWD%
+:perform_install_files_done
+
+:perform_install_libraries
+echo Installing CRT files ...
+copy /Y %MYVCC_REDIST_DLLS% %MYOUT_FINAL%\bin^%MYLOG_APPEND% 
+if not %ERRORLEVEL%==0 goto error_install
+if "%MYVCC_REDIST_DLLS_2%"=="" goto perform_install_libraries_done
+copy /Y %MYVCC_REDIST_DLLS_2% %MYOUT_FINAL%\bin^%MYLOG_APPEND% 
+if not %ERRORLEVEL%==0 goto error_install
+if "%MYVCC_REDIST_DLLS_3%"=="" goto perform_install_libraries_done
+copy /Y %MYVCC_REDIST_DLLS_3% %MYOUT_FINAL%\bin^%MYLOG_APPEND% 
+if not %ERRORLEVEL%==0 goto error_install
+:perform_install_libraries_done
+
+:perform_install_readme
+echo Installing readme ...
+copy /Y readme.tool-win%MY_ENV_SCRIPT_SUFFIX% %MYOUT_FINAL%\readme.tool^%MYLOG_APPEND% 
+if not %ERRORLEVEL%==0 goto error_install
+:perform_install_readme_done
+
+:perform_gen_patch
+echo Creating patch file ...
+for /F %%i in ('kmk_ash.exe -c "svn log -r 1:HEAD --limit 1 --stop-on-copy | kmk_sed.exe -n -e ""2s/^r\([0-9]\{1,\}\) .*$/\1/p"""') do set BASEREV=%%i
+svn diff --ignore-properties -r %BASEREV%:HEAD > %MYOUT_FINAL%\qt.patch
+if not %ERRORLEVEL%==0 goto error_general
+:perform_gen_patch_done
+
+:make_pkg
+echo Determining the tree revision ...
+set MYREV=XXXX
+set LC_ALL=C
+for /F %%i in ('kmk_ash.exe -c "svn info . | kmk_sed.exe  -e /Revision/\!d -e s/Revision:\ *// "') do set MYREV=%%i
+echo MYREV=%MYREV%
+if "%MYREV%"=="" set MYREV=XXX
+set MYPKG=..\win.amd64.qt.v%MYQT_VERSION%-r%MYREV%.zip
+echo Zipping final package (%MYPKG%) ...
+cd %MYOUT_FINAL%
+zip -9rX %MYPKG% . -x *.pdb^%MYLOG_APPEND% 
+if not %ERRORLEVEL%==0 goto error_install
+cd %MYPWD%
+set MYPKGPDB=..\win.amd64.qt.pdb.v%MYQT_VERSION%-r%MYREV%.zip
+echo Zipping the pdb package (%MYPKGPDB%) ...
+cd %MYOUT_FINAL%
+zip -9rX %MYPKGPDB% . -i *.pdb^%MYLOG_APPEND% 
+if not %ERRORLEVEL%==0 goto error_install
+echo The tools/Makefile values for the zip files:
+kmk_md5sum -b %MYPKG%
+FOR /F "usebackq" %%i IN ('%MYPKG%')    DO echo %%i_SIZE = %%~zi
+kmk_md5sum -b %MYPKGPDB%
+FOR /F "usebackq" %%i IN ('%MYPKGPDB%') DO echo %%i_SIZE = %%~zi
+cd %MYPWD%
+:make_pkg_done
+
+goto end
+
+
+:error_install
+echo ERROR: The packaging failed, check the tail of vbox-install.log for details.
+goto error_end
+
+:error_general
+echo ERROR: The packaging failed, see above error messages for more information.
+goto error_end
+
+:error_end
+cd %MYPWD%
+endlocal
+exit /b 1
+
+:end
+endlocal
+exit /b 0
+
