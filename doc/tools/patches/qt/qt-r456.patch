@@ -0,0 +1,56 @@
+@echo off
+setlocal
+
+goto startup
+:description
+echo(
+echo Removes all unversionized files.
+echo Note: can be executed as a part of vbox-do-it-all.cmd call.
+echo Note: running this script manually will cause FULL Qt rebuild!
+echo   Usage:
+echo     vbox-clean-all.cmd [/?] ^| [verbose]
+echo   Options:
+echo     ?          shows this help.
+echo     verbose    refers to verbose script output and is done when case-insensitive "verbose" option is given.
+goto error_end
+
+:startup
+set MYLOG=">NUL 2>&1"
+if "%1"=="" goto startup_done
+if not "%2"=="" goto description
+if /i "%1"=="verbose" (set MYLOG=) else (goto description)
+:startup_done
+
+:perform_setup
+if not "%MYQT_VERSION%"=="" goto perform_setup_done
+call vbox-env.cmd || goto error_end
+:perform_setup_done
+
+:gather_files
+echo Gathering unversionized files ...
+set FILE_LST=files-to-delete.lst
+svn st --no-ignore | "kmk_sed.exe" -e '/^[I?]/!d' -e 's/^.......//' > %FILE_LST%
+if not %ERRORLEVEL%==0 goto error_svn
+:gather_files_done
+
+:remove_files
+echo Deleting them ...
+for /F %%i in (%FILE_LST%) do "kmk_rm.exe" -Rfv ".\%%i" ^%MYLOG% 
+if exist %FILE_LST% del %FILE_LST%
+:remove_files_done
+
+goto end
+
+
+:error_svn
+echo ERROR: Unable to get unversionized files from SVN status.
+goto error_end
+
+:error_end
+endlocal
+exit /b 1
+
+:end
+endlocal
+exit /b 0
+
