+static GdkColor fromQColor(const QColor &color)
+{
+    GdkColor retval;
+    retval.pixel = 0;
+    retval.red = color.red() * 255;
+    retval.green = color.green() * 255;
+    retval.blue = color.blue() * 255;
+    return retval;
+}
