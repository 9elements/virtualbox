+    echo
+    echo "     The options are as follows:"
+    echo "     -h (--help)          Prints this help."
+    echo "     -c (--clean)         Performs cleanup first of all."
+    echo "     -v (--verbose)       Requests verbose script output."
+    echo
+}
+
+# Cleanup function:
+Cleanup()
+{
+    echo "Performing cleanup ..."
+    ./vbox-clean-all.sh $1
+    if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+        echo '* ./vbox-clean-all.sh failed! *'
+        exit 1
+    fi
+}
+
+# Setup:
+VERSION=`svn info|sed -e '/^Relative URL/!d' -e 's/^Relative URL[^0-9.]*\(.*\)/\1/'`
+REVISION=`svn info|sed -e '/^Last Changed Rev/!d' -e 's/^Last Changed Rev: *\(.*\)/\1/'`
+OUTPUT_FOLDER=out
+if [ ! -d $OUTPUT_FOLDER ]; then
+    mkdir $OUTPUT_FOLDER
+fi
+if [ ! -f $OUTPUT_FOLDER/vbox-svn ]; then
+    echo $VERSION > $OUTPUT_FOLDER/vbox-svn
+    echo $REVISION >> $OUTPUT_FOLDER/vbox-svn
+fi
+case `hostname` in
+    tinderlin4)
+        # use ol7-amd64-jail if available (to satisfy minimum requirements)
+        [ -f $HOME/jails/enter-ol7-amd64-jail ] && MAYBE_CHROOT="$HOME/jails/enter-ol7-amd64-jail";;
+    tinderlin)
+        # use qt6-ol8.0-amd64 container if available (to satisfy minimum requirements)
+        MAYBE_CHROOT="$PWD/../client/jail.sh qt6-ol8.0-amd64";;
+esac
+
+# Handle arguments:
+while getopts ":cvh-:" option; do
+    case $option in
+        -) # full names
+            case $OPTARG in
+                clean) # perform Cleanup
+                    Cleanup $OPTIONS;;
+                verbose) # request Verbose output
+                    OPTIONS=-v;;
+                help) # display Help
+                    Help
+                    exit 2;;
+                *) # invalid argument
+                    echo "Error: Illegal option"
+                    exit 2;;
+            esac;;
+        c) # perform Cleanup
+            Cleanup $OPTIONS;;
+        v) # request Verbose output
+            OPTIONS=-v;;
+        h) # display Help
+            Help
+            exit 2;;
+        *) # invalid argument
+            echo "Error: Illegal option"
+            exit 2;;
+    esac
+done
+
+# Start notification:
+if command -v send_notification.sh > /dev/null; then
+    TIME=`date +%T`
+    send_notification.sh "$TIME: Qt $VERSION@$REVISION build started ..."
+fi
+
+# Generate patch:
+if [ ! -f $OUTPUT_FOLDER/qt.patch ]; then
+    echo 'Generating patch, please wait ...'
+    BASEREV=`svn log -r 1:HEAD --limit 1 --stop-on-copy | sed -n -e '2s/^r\([0-9]\{1,\}\) .*$/\1/p'`
+    svn diff \
+        --ignore-properties \
+        -r ${BASEREV}:HEAD \
+        > $OUTPUT_FOLDER/qt.patch
+    if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+        echo '* svn diff failed!'
+        exit 1
+    fi
+fi
+
+# Configure:
+if [ ! -f $OUTPUT_FOLDER/vbox-configured ]; then
+    $MAYBE_CHROOT ./vbox-configure-linux.sh $OPTIONS
+    if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+        echo '* ./vbox-configure-linux.sh failed! *'
+        exit 1
+    fi
+    > $OUTPUT_FOLDER/vbox-configured
+fi
+
+# Build:
+if [ ! -f $OUTPUT_FOLDER/vbox-built ]; then
+    $MAYBE_CHROOT ./vbox-build-all-linux.sh $OPTIONS
+    if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+        echo '* ./vbox-build-all-linux.sh failed! *'
+        exit 1
+    fi
+    > $OUTPUT_FOLDER/vbox-built
+fi
+
+# Install:
+if [ ! -f $OUTPUT_FOLDER/vbox-installed ]; then
+    $MAYBE_CHROOT ./vbox-make-package-linux.sh $OPTIONS
+    if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+        echo '* ./vbox-make-package-linux.sh failed! *'
+        exit 1
+    fi
+    > $OUTPUT_FOLDER/vbox-installed
+fi
+
+# Finish notification:
+if command -v send_notification.sh > /dev/null; then
+    TIME=`date +%T`
+    send_notification.sh "$TIME: Qt $VERSION@$REVISION build complete!"
+fi
+
+echo 'Package successfully prepared!'
+exit 0
+
