+@echo off
+
+goto startup
+:description
+echo(
+echo Fetches sdk and compiler environment, required to
+echo [re]configure, [re]build and [re]pack of VirtulBox-compatible Qt tool for Windows ARM64.
+echo Note:   can be executed as a part of other scripts.
+echo Note 2: relies on --ucrt option of sdk env-arm64.cmd to get ucrt includes/libs.
+echo Note 3: would be great to have --winrt option in sdk env-arm64.cmd as well.
+echo   Usage:
+echo     vbox-env.cmd [/?]
+echo   Options:
+echo     ?    shows this help.
+goto error_end
+
+:startup
+if "%1"=="/?" goto description
+echo Setting up the environment ...
+set MYSDK_VERSION=v10.0.26100.0
+set MYSDK_SHORTVERSION=10.0.26100.0
+set MYVCC_VERSION=v14.3.17.11.5
+set MYVCC_SHORTVERSION=143
+set MYCONF_TOOL=cmake
+set MYQT_VERSION=6.8.0
+set MYOUT_BUILD=out-arm
+set MYOUT_BASE=%~p0staged-install
+set MYOUT_FINAL=%MYOUT_BASE%\VBoxQtArm
+set MYOUT_FINAL_ABSOLUTE_AMD64=%~dp0staged-install\VBoxQt
+
+:check_files
+if "%KBUILD_DEVTOOLS%"=="" goto error_no_bearings
+set MYFILE=%KBUILD_DEVTOOLS%\win\sdk\%MYSDK_VERSION%\env-arm64.cmd
+if not exist %MYFILE% goto error_missing_file
+set MYFILE=%KBUILD_DEVTOOLS%\win\vcc\%MYVCC_VERSION%\env-arm64.cmd
+if not exist %MYFILE% goto error_missing_file
+:check_files_done
+
+:prepare_environment
+call %KBUILD_DEVTOOLS%\win\sdk\%MYSDK_VERSION%\env-arm64.cmd --ucrt
+call %KBUILD_DEVTOOLS%\win\vcc\%MYVCC_VERSION%\env-arm64.cmd
+
+set MYVCC_REDIST_DLLS="%VCREDISTDIR%\arm64\Microsoft.VC%MYVCC_SHORTVERSION%.CRT\msvc?140*.dll"
+set MYVCC_REDIST_DLLS_2="%VCREDISTDIR%\arm64\Microsoft.VC%MYVCC_SHORTVERSION%.CRT\vcruntime140*.dll"
+
+rem This one is required because sdk env-arm64.cmd doesn't have --winrt
+set INCLUDE=%KBUILD_DEVTOOLS%\win\sdk\%MYSDK_VERSION%\Include\%MYSDK_SHORTVERSION%\winrt;%INCLUDE%
+
+rem A package of amd64 tools for cross-build:
+set Path=%KBUILD_DEVTOOLS%\win\sdk\%MYSDK_VERSION%\bin\%MYSDK_SHORTVERSION%\x64;^
+%KBUILD_DEVTOOLS%\..\kBuild\bin\win.amd64;%Path%
+:prepare_environment_done
+
+goto end
+
+
+:error_no_bearings
+echo ERROR: The KBUILD_DEVTOOLS variable is not set.
+goto error_end
+
+:error_missing_file
+echo ERROR: The file %MYFILE% is missing.
+goto error_end
+
+:error_end
+set MYFILE=
+exit /b 1
+
+:end
+set MYFILE=
+exit /b 0
+
