+#!/bin/bash
+
+# Help function:
+Help()
+{
+    echo
+    echo "NAME"
+    echo "     vbox-do-it-all-darwin.sh"
+    echo
+    echo "SYNOPSIS"
+    echo "     vbox-do-it-all-darwin.sh [-h | -c | -v]"
+    echo
+    echo "DESCRIPTION"
+    echo "     Performs whole the job for you, by "
+    echo "     [re]configuring, [re]building and [re]packing "
+    echo "     a VirtulBox-compatible Qt tool for macOS."
+    echo
+    echo "     The options are as follows:"
+    echo "     -h (--help)          Prints this help."
+    echo "     -c (--clean)         Performs cleanup first of all."
+    echo "     -v (--verbose)       Requests verbose script output."
+    echo
+}
+
+# Cleanup function:
+Cleanup()
+{
+    echo "Performing cleanup ..."
+    ./vbox-clean-all.sh $1
+    if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+        echo '* ./vbox-clean-all.sh failed! *'
+        exit 1
+    fi
+}
+
+# Setup:
+VERSION=`svn info|sed -e '/^Relative URL/!d' -e 's/^Relative URL[^0-9.]*\(.*\)/\1/'`
+OUTPUT_FOLDER=out
+
+# Handle arguments:
+while getopts ":cvh-:" option; do
+    case $option in
+        -) # full names
+            case $OPTARG in
+                clean) # perform Cleanup
+                    Cleanup $OPTIONS;;
+                verbose) # request Verbose output
+                    OPTIONS=-v;;
+                help) # display Help
+                    Help
+                    exit 2;;
+                *) # invalid argument
+                    echo "Error: Illegal option"
+                    exit 2;;
+            esac;;
+        c) # perform Cleanup
+            Cleanup $OPTIONS;;
+        v) # request Verbose output
+            OPTIONS=-v;;
+        h) # display Help
+            Help
+            exit 2;;
+        *) # invalid argument
+            echo "Error: Illegal option"
+            exit 2;;
+    esac
+done
+
+# Start notification:
+if command -v send_notification.sh > /dev/null; then
+    TIME=`date +%T`
+    send_notification.sh "$TIME: Qt $VERSION build started ..."
+fi
+
+# Configure:
+if [ ! -f $OUTPUT_FOLDER/vbox-configured ]; then
+    ./vbox-configure-darwin.sh $OPTIONS
+    if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+        echo '* ./vbox-configure-darwin.sh failed! *'
+        exit 1
+    fi
+    > $OUTPUT_FOLDER/vbox-configured
+fi
+
+# Build:
+if [ ! -f $OUTPUT_FOLDER/vbox-built ]; then
+    ./vbox-build-all-darwin.sh $OPTIONS
+    if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+        echo '* ./vbox-build-all-darwin.sh failed! *'
+        exit 1
+    fi
+    > $OUTPUT_FOLDER/vbox-built
+fi
+
+# Install:
+if [ ! -f $OUTPUT_FOLDER/vbox-installed ]; then
+    ./vbox-make-package-darwin.sh $OPTIONS
+    if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+        echo '* ./vbox-make-package-darwin.sh failed! *'
+        exit 1
+    fi
+    > $OUTPUT_FOLDER/vbox-installed
+fi
+
+# Finish notification:
+if command -v send_notification.sh > /dev/null; then
+    TIME=`date +%T`
+    send_notification.sh "$TIME: Qt $VERSION build complete!"
+fi
+
+echo 'Package successfully prepared!'
+exit 0
+
