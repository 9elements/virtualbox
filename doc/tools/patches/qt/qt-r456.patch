+    echo "     -v (--verbose)       Requests verbose script output."
+    echo
+}
+
+# Setup:
+WORK_FOLDER=`pwd`
+OUTPUT_FOLDER=out
+LOG_FILE=$WORK_FOLDER/vbox-configure.log
+
+# Handle arguments:
+while getopts ":vh-:" option; do
+    case $option in
+        -) # full names
+            case $OPTARG in
+                verbose) # request Verbose output
+                    LOG_FILE=/dev/stdout;;
+                help) # display Help
+                    Help
+                    exit 2;;
+                *) # invalid argument
