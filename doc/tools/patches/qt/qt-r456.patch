Index: vbox-configure-arm.cmd
===================================================================
--- vbox-configure-arm.cmd	(nonexistent)
+++ vbox-configure-arm.cmd	(revision 456)
@@ -0,0 +1,126 @@
+@echo off
+setlocal
+
+goto startup
+:description
+echo(
+echo [Re]configures a VirtulBox-compatible Qt tool for Windows ARM64.
+echo Note: can be executed as a part of vbox-do-it-all.cmd call.
+echo Note: running this script manually may cause FULL Qt rebuild!
+echo   Usage:
+echo     vbox-configure-arm.cmd [verbose]
+echo   Options:
+echo     ?          shows this help.
+echo     verbose    refers to verbose script output and is done when case-insensitive "verbose" option is given.
+goto error_end
+
+:startup
+set MYPWD=%CD%
+for /f "tokens=*" %%d in ('cd') do set MYPWD=%%d
+set MYLOG_START="> %MYPWD%\vbox-configure-arm.log 2>&1"
+set MYLOG_APPEND=">> %MYPWD%\vbox-configure-arm.log 2>&1"
+if "%1"=="" goto startup_done
+if not "%2"=="" goto description
+if /i "%1"=="verbose" (set MYLOG_START= && set MYLOG_APPEND=) else (goto description)
+:startup_done
+
+:perform_setup
+if not "%MYQT_VERSION%"=="" goto perform_setup_done
+call vbox-env-arm.cmd || goto error_end
+:perform_setup_done
+
+rem
+rem We would like to use "." as prefix here, because that means that
+rem QLibraryInfo::location will replace it with the application directory
+rem because it's relative (we have a reasonable chance of keeping the
+rem application dir under control, hardening wise).  However, qmake does
+rem weird stuff when we do this, we end up with the dir of the qmake.exe
+rem binary replacing the "." in all the install rules in the makefiles,
+rem or maybe it's the current directory.  Because of this we cannot do that.
+rem
+rem Using "" forces us to specify every directory with defaults because
+rem configure wants to do a flat mess for some reason.
+rem 
+rem So, instead we use "/VBoxQtArm" and use SED to edit the path that ends up in the
+rem actual binaries, so it is relative and totally invalid.  We also zap the
+rem plugins string too so it won't be considered.
+rem
+rem Note! Since the qmake we use for building is built by configure, it will
+rem       get the unmodified qconfig.cpp value, i.e. the "/VBoxQtArm" prefix.
+rem
+
+:perform_configure
+if not exist %MYOUT_BUILD%\ mkdir %MYOUT_BUILD%
+cd %MYOUT_BUILD%
+set MY_QCONFIG_PRI=qtbase\mkspecs\qconfig.pri
+if exist %MY_QCONFIG_PRI% del %MY_QCONFIG_PRI%
+echo Configuring for ARM64 ...
+call %MYPWD%\configure.bat ^
+    QT_FORCE_BUILD_TOOLS=ON ^
+    -platform win32-arm64-msvc ^
+    -qt-host-path %MYOUT_FINAL_ABSOLUTE_AMD64% ^
+    -release ^
+    -shared ^
+    -force-debug-info ^
+    -qtlibinfix VBox ^
+    -prefix "/VBoxQtArm" ^
+    -no-cups ^
+    -no-dbus ^
+    -no-directfb ^
+    -no-eglfs ^
+    -no-gif ^
+    -no-glib ^
+    -no-rpath ^
+    -no-linuxfb ^
+    -no-kms ^
+    -no-linuxfb ^
+    -no-openssl ^%MYLOG_START% 
+
+if not %ERRORLEVEL%==0 goto error_configure
+:perform_configure_done
+
+rem
+rem As mentioned above, we edit the -prefix path that gets embedded into our
+rem binaries so that is is an relative and totally invalid (Win32) path.  This
+rem is to prevent repeats of the \\plugins\ problem we had early with Qt5.  It
+rem is also some insurance against accidental use of the actual path.
+rem
+rem We also clear the plugins path here so it won't be used.  QLibraryInfo::location
+rem won't expand empty value, just pass them to the caller).
+rem Note! Must keep the character count the same as the string is index.
+rem
+
+:perform_adjust_config
+echo Adjusting built-in configuration string a little bit ...
+copy /Y qtbase\src\corelib\global\qconfig.cpp qtbase\src\corelib\global\qconfig.cpp.old^%MYLOG_APPEND% 
+if not %ERRORLEVEL%==0 goto error_end
+"kmk_sed.exe" ^
+    -e "s,qt_prfxpath=.*\/VBoxQtArm,qt_prfxpath=nul\/VirtualBox*qt:invalid?prefix\/replaced|by<app-dir>," ^
+    qtbase\src\corelib\global\qconfig.cpp.old --output qtbase\src\corelib\global\qconfig.cpp
+if not %ERRORLEVEL%==0 goto error_end
+type qtbase\src\corelib\global\qconfig.cpp^%MYLOG_APPEND% 
+if not exist %MY_QCONFIG_PRI% goto error_qconfig_pri_missing
+echo Configuration successful!
+:perform_adjust_config_done
+
+cd %MYPWD%
+goto end
+
+
+:error_configure
+echo ERROR: Configure failed, check the tail of vbox-configure-arm.log for details.
+goto error_end
+
+:error_qconfig_pri_missing
+echo ERROR: Configure failed, %MY_QCONFIG_PRI% is missing.
+goto error_end
+
+:error_end
+cd %MYPWD%
+endlocal
+exit /b 1
+
+:end
+endlocal
+exit /b 0
+
