@@ -0,0 +1,143 @@
+#!/bin/bash
+
+# Help function:
+Help()
+{
+    echo
+    echo "NAME"
+    echo "     vbox-make-package-linux.sh"
+    echo
+    echo "SYNOPSIS"
+    echo "     vbox-make-package-linux.sh [-h | -v]"
+    echo
+    echo "DESCRIPTION"
+    echo "     Packs a VirtulBox-compatible Qt tool for Linux."
+    echo
+    echo "     The options are as follows:"
+    echo "     -h (--help)          Prints this help."
+    echo "     -v (--verbose)       Requests verbose script output."
+    echo
+}
+
+# Setup:
+WORK_FOLDER=`pwd`
+OUTPUT_FOLDER=out
+INSTALL_FOLDER=staged-install
+INSTALL_FOLDER_FULL=$WORK_FOLDER/$INSTALL_FOLDER
+PREFIX=/opt/VirtualBox
+LOG_FILE=$WORK_FOLDER/vbox-install.log
+
+# Validate:
+readarray -t lines < $OUTPUT_FOLDER/vbox-svn
+VERSION=${lines[0]}
+REVISION=${lines[1]}
+if [ -z "$VERSION" ]; then
+    VERSION=`svn info|sed -e '/^Relative URL/!d' -e 's/^Relative URL[^0-9.]*\(.*\)/\1/'`
+fi
+if [ -z "$REVISION" ]; then
+    REVISION=`svn info|sed -e '/^Last Changed Rev/!d' -e 's/^Last Changed Rev: *\(.*\)/\1/'`
+fi
+if [ -z "$VERSION" ]; then
+    echo 'Cannot determine version!'
+    exit 1
+fi
+if [ -z "$REVISION" ]; then
+    echo 'Cannot determine revision!'
+    exit 1
+fi
+
+# Handle arguments:
+while getopts ":vh-:" option; do
+    case $option in
+        -) # full names
+            case $OPTARG in
+                verbose) # request Verbose output
+                    LOG_FILE=/dev/stdout;;
+                help) # display Help
+                    Help
+                    exit 2;;
+                *) # invalid argument
+                    echo "Error: Illegal option"
+                    exit 2;;
+            esac;;
+        v) # request Verbose output
+            LOG_FILE=/dev/stdout;;
+        h) # display Help
+            Help
+            exit 2;;
+        *) # invalid argument
+            echo "Error: Illegal option"
+            exit 2;;
+    esac
+done
+
+# Install:
+cd $OUTPUT_FOLDER
+echo 'Installing ...'
+rm -Rf $INSTALL_FOLDER_FULL
+cmake --install . --prefix $INSTALL_FOLDER_FULL$PREFIX > $LOG_FILE 2>&1
+if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+    echo '* make install failed, have a look at vbox-install.log for details! *'
+    exit 1
+fi
+cd $WORK_FOLDER
+
+# Save some space by removing some unused libraries:
+cd $INSTALL_FOLDER$PREFIX/lib
+for i in \
+    Qt6TestVBox \
+    ; do
+    rm -r `find . -name \*$i*`
+done
+cd - > /dev/null
+
+# Copy stuff:
+set -e
+cp -v readme.tool-linux ./$INSTALL_FOLDER$PREFIX/readme.tool >> $LOG_FILE 2>&1
+if [ -f $OUTPUT_FOLDER/qt.patch ]; then
+    cp -v $OUTPUT_FOLDER/qt.patch ./$INSTALL_FOLDER$PREFIX/
+fi
+set +e
+
+# Move the .debug files into a separate directory, easier to tar
+echo 'Preparing tar packages ...'
+cd $INSTALL_FOLDER$PREFIX/
+for f in `find . -name \*debug`; do
+    dir=debug/`dirname $f`
+    mkdir -p $INSTALL_FOLDER_FULL/$dir
+    mv $f $INSTALL_FOLDER_FULL/$dir
+done
+cd - > /dev/null
+
+# Strip all remaining files
+cd $INSTALL_FOLDER$PREFIX/
+find . -type f|xargs file|grep "not stripped"|cut -f1 -d':'|xargs strip
+cd - > /dev/null
+
+# Tar it up:
+tar cjvf \
+    $INSTALL_FOLDER/linux.amd64.qt.v${VERSION}-r${REVISION}.tar.bz2 \
+    -C $INSTALL_FOLDER$PREFIX/ . \
+    >> $LOG_FILE 2>&1
+if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+    echo '* tar failed, have a look at vbox-install.log for details!'
+    exit 1
+fi
+
+tar cjvf \
+    $INSTALL_FOLDER/linux.amd64.qt.dbg.v${VERSION}-r${REVISION}.tar.bz2 \
+    -C $INSTALL_FOLDER/debug . \
+    >> $LOG_FILE 2>&1
+if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+    echo '* tar/dbg failed, have a look at vbox-install.log for details!'
+    exit 1
+fi
+
+echo "linux.amd64.qt.v${VERSION}-r${REVISION}.tar.bz2_MD5  = `md5sum $INSTALL_FOLDER/linux.amd64.qt.v${VERSION}-r${REVISION}.tar.bz2 | awk '{ print $1 }'`"
+echo "linux.amd64.qt.v${VERSION}-r${REVISION}.tar.bz2_SIZE = `stat -c %s $INSTALL_FOLDER/linux.amd64.qt.v${VERSION}-r${REVISION}.tar.bz2`"
+
+echo "linux.amd64.qt.dbg.v${VERSION}-r${REVISION}.tar.bz2_MD5  = `md5sum $INSTALL_FOLDER/linux.amd64.qt.dbg.v${VERSION}-r${REVISION}.tar.bz2 | awk '{ print $1 }'`"
+echo "linux.amd64.qt.dbg.v${VERSION}-r${REVISION}.tar.bz2_SIZE = `stat -c %s $INSTALL_FOLDER/linux.amd64.qt.dbg.v${VERSION}-r${REVISION}.tar.bz2`"
+
+exit 0
+
