+{
+    echo
+    echo "NAME"
+    echo "     vbox-build-all-darwin.sh"
+    echo
+    echo "SYNOPSIS"
+    echo "     vbox-build-all-darwin.sh [-h | -v]"
+    echo
+    echo "DESCRIPTION"
+    echo "     Builds a VirtulBox-compatible Qt tool for macOS."
+    echo
+    echo "     The options are as follows:"
+    echo "     -h (--help)          Prints this help."
+    echo "     -v (--verbose)       Requests verbose script output."
+    echo
+}
+
+# Setup:
+CPUS=`sysctl -n hw.ncpu`
+WORK_FOLDER=`pwd`
+OUTPUT_FOLDER=out
+LOG_FILE=$WORK_FOLDER/vbox-build.log
+
+# Handle arguments:
+while getopts ":vh-:" option; do
+    case $option in
+        -) # full names
+            case $OPTARG in
+                verbose) # request Verbose output
+                    LOG_FILE=/dev/stdout;;
+                help) # display Help
+                    Help
+                    exit 2;;
+                *) # invalid argument
+                    echo "Error: Illegal option"
+                    exit 2;;
+            esac;;
+        v) # request Verbose output
+            LOG_FILE=/dev/stdout;;
+        h) # display Help
+            Help
+            exit 2;;
+        *) # invalid argument
+            echo "Error: Illegal option"
+            exit 2;;
+    esac
+done
+
+# Build:
+cd $OUTPUT_FOLDER
+echo Building ...
+cmake --build . --parallel $CPUS > $LOG_FILE 2>&1
+if [[ ${PIPESTATUS[0]} -ne 0 || ${PIPESTATUS[1]} -ne 0 ]]; then
+    echo '* make failed, have a look at vbox-build.log for details! *'
+    exit 1
