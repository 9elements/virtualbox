+    /**
+     * Caches the single HTML document during the pushMetadata topic phase. 
+     * Expecting only getDocument and writeDocument calls.
+     */
+    private final class CacheStoreSingleDitaFile implements Store {
+
+        private final Store fallbackStore;
+        private final URI singleDitaFile;
+        private Document singleDitaDoc;
+        private long lastModified;
+        private final DITAOTLogger logger;
+
+        CacheStoreSingleDitaFile(final Store fallbackStore, final URI singleDitaFile, final DITAOTLogger logger) {
+            this.fallbackStore = fallbackStore;
+            this.singleDitaFile = singleDitaFile.normalize();
+            this.singleDitaDoc = null;
+            this.lastModified = -1;
+            this.logger = logger;
+            logger.info("CacheStoreSingleDitaFile: singleDitaFile=" + this.singleDitaFile.toString());
+        }
+
+        public void flushSingleDoc() throws IOException {
+            if (singleDitaDoc != null) {
+                logger.info("CacheStoreSingleDitaFile: flush");
+                fallbackStore.writeDocument(singleDitaDoc, singleDitaFile);
+                singleDitaDoc = null;
+            }
+        }
+
+        private void flushSingleDocThrowIoXcpt(final URI path) throws IOException {
+            if (singleDitaFile.equals(path.normalize())) {
+                flushSingleDoc();
+            }
+        }
+
+        private void flushSingleDocThrowDitaXcpt(final URI path) throws DITAOTException {
+            try {
+                flushSingleDocThrowIoXcpt(path);
+            } catch (IOException oXcpt) {
+                throw new DITAOTException(oXcpt.toString());
+            }
+        }
+
+        public void transform(final URI src, final ContentHandler contentHandler) throws DITAOTException {
+            logger.error("CacheStoreSingleDitaFile: transform #1: " + src.toString());
+            assert false;
+            flushSingleDocThrowDitaXcpt(src);
+            fallbackStore.transform(src, contentHandler);
+        }
+
+        public void transform(final URI src, final List<XMLFilter> filters) throws DITAOTException {
+            logger.error("CacheStoreSingleDitaFile: transform #2: " + src.toString());
+            assert false;
+            flushSingleDocThrowDitaXcpt(src);
+            fallbackStore.transform(src, filters);
+        }
+
+        public void transform(final URI src, final URI dst, final List<XMLFilter> filters) throws DITAOTException {
+            logger.error("CacheStoreSingleDitaFile: transform #3: " + src.toString() + " => " + dst.toString());
+            assert false;
+            flushSingleDocThrowDitaXcpt(src);
+            flushSingleDocThrowDitaXcpt(dst);
+            fallbackStore.transform(src, dst, filters);
+        }
+
+        public void transform(final URI src, final XsltTransformer transformer) throws DITAOTException {
+            logger.error("CacheStoreSingleDitaFile: transform #4: " + src.toString());
+            assert false;
+            flushSingleDocThrowDitaXcpt(src);
+            fallbackStore.transform(src, transformer);
+        }
+
+        public void transform(final URI src, final URI dst, final XsltTransformer transformer) throws DITAOTException {
+            logger.error("CacheStoreSingleDitaFile: transform #5: " + src.toString() + " => " + dst.toString());
+            assert false;
+            flushSingleDocThrowDitaXcpt(src);
+            flushSingleDocThrowDitaXcpt(dst);
+            fallbackStore.transform(src, transformer);
+        }
+
+        public Source getSource(URI path) {
+            logger.error("CacheStoreSingleDitaFile: getSource " + path.toString());
+            assert false;
+            try {
+                flushSingleDocThrowIoXcpt(path);
+            } catch (IOException oXctp) {
+                logger.error("CacheStoreSingleDitaFile: flushSingleDocThrowIoXcpt failed " + oXctp.toString());
+            }
+            return fallbackStore.getSource(path);
+        }
+
+        public Document getImmutableDocument(URI path) throws IOException {
+            logger.error("CacheStoreSingleDitaFile: getImmutableDocument: " + path.toString());
+            assert false;
+            flushSingleDocThrowIoXcpt(path);
+            return fallbackStore.getImmutableDocument(path);
+        }
+
+        public XdmNode getImmutableNode(final URI path) throws IOException {
+            logger.error("CacheStoreSingleDitaFile: getImmutableNode: " + path.toString());
+            assert false;
+            flushSingleDocThrowIoXcpt(path);
+            return fallbackStore.getImmutableNode(path);
+        }
+
+        public Document getDocument(URI path) throws IOException {
+            if (singleDitaFile.equals(path.normalize())) {
+                if (singleDitaDoc != null) {
+                    logger.info("CacheStoreSingleDitaFile: getDocument hit");
+                    return singleDitaDoc;
+                }
+                logger.info("CacheStoreSingleDitaFile: getDocument first");
+                singleDitaDoc = fallbackStore.getDocument(path);
+                return singleDitaDoc;
+            }
+            logger.warn("CacheStoreSingleDitaFile: getDocument miss: " + path.toString());
+            assert false;
+            return fallbackStore.getDocument(path);
+        }
+
+        public void writeDocument(Document doc, URI dst) throws IOException {
+            if (singleDitaFile.equals(dst.normalize())) {
+                singleDitaDoc = doc;
+                lastModified = System.currentTimeMillis();
+                logger.info("CacheStoreSingleDitaFile: writeDocument hit");
+            } else {
+                logger.warn("CacheStoreSingleDitaFile: writeDocument miss: " + dst.toString());
+                fallbackStore.writeDocument(doc, dst);
+                assert false;
+            }
+        }
+
+        public void writeDocument(Node doc, final ContentHandler dst) throws IOException {
+            logger.error("CacheStoreSingleDitaFile: writeDocument miss/#1");
+            fallbackStore.writeDocument(doc, dst);
+            assert false;
+        }
+
+        public void writeDocument(XdmNode node, final ContentHandler dst) throws IOException {
+            logger.error("CacheStoreSingleDitaFile: writeDocument miss/#2");
+            fallbackStore.writeDocument(node, dst);
+            assert false;
+        }
+
+        public void writeDocument(XdmNode node, URI dst) throws IOException {
+            logger.error("CacheStoreSingleDitaFile: writeDocument miss/#3: " + dst.toString());
+            fallbackStore.writeDocument(node, dst);
+            assert false;
+        }
+
+        public Destination getDestination(URI path) throws IOException {
+            logger.error("CacheStoreSingleDitaFile: getDestination " + path.toString());
+            assert false;
+            return fallbackStore.getDestination(path);
+        }
+
+        public ContentHandler getContentHandler(URI path) throws SaxonApiException, IOException {
+            logger.error("CacheStoreSingleDitaFile: getContentHandler " + path.toString());
+            assert false;
+            flushSingleDocThrowIoXcpt(path);
+            return fallbackStore.getContentHandler(path);
+        }
+
+        public URI getUri(URI path) {
+            logger.error("CacheStoreSingleDitaFile: getUri " + path.toString());
+            assert false;
+            return fallbackStore.getUri(path);
+        }
+
+        public void delete(URI file) throws IOException {
+            logger.error("CacheStoreSingleDitaFile: delete " + file.toString());
+            assert false;
+            if (singleDitaFile.equals(file.normalize())) {
+                singleDitaDoc = null;
+                logger.info("CacheStoreSingleDitaFile: delete hit");
+            }
+            fallbackStore.delete(file);
+        }
+
+        public void copy(URI src, URI dst) throws IOException {
+            logger.error("CacheStoreSingleDitaFile: copy " + src.toString() + " -> " + dst.toString());
+            assert false;
+            flushSingleDocThrowIoXcpt(src);
+            fallbackStore.copy(src, dst);
+            if (singleDitaDoc != null && singleDitaFile.equals(dst.normalize())) {
+                singleDitaDoc = null;
+                logger.info("CacheStoreSingleDitaFile: copy hit");
+            }
+        }
+
+        public boolean exists(URI path) {
+            if (singleDitaDoc != null && singleDitaFile.equals(path.normalize())) {
+                logger.info("CacheStoreSingleDitaFile: exists hit");
+                return true;
+            }
+            logger.error("CacheStoreSingleDitaFile: exists " + path.toString());
+            assert false;
+            return fallbackStore.exists(path);
+        }
+
+        public long getLastModified(URI path) {
+            if (singleDitaDoc != null && singleDitaFile.equals(path.normalize())) {
+                logger.info("CacheStoreSingleDitaFile: getLastModified hit");
+                return lastModified;
+            }
+            logger.error("CacheStoreSingleDitaFile: getLastModified " + path.toString());
+            assert false;
+            return fallbackStore.getLastModified(path);
+        }
+
+        public void move(URI src, URI dst) throws IOException {
+            logger.error("CacheStoreSingleDitaFile: move " + src.toString() + " -> " + dst.toString());
+            assert false;
+            flushSingleDocThrowIoXcpt(src);
+            fallbackStore.move(src, dst);
+            if (singleDitaDoc != null && singleDitaFile.equals(dst.normalize())) {
+                singleDitaDoc = null;
+                logger.info("CacheStoreSingleDitaFile: move hit");
+            }
+        }
+
+        public InputStream getInputStream(URI path) throws IOException {
+            logger.error("CacheStoreSingleDitaFile: getInputStream " + path.toString());
+            assert false;
+            flushSingleDocThrowIoXcpt(path);
+            return fallbackStore.getInputStream(path);
+        }
+
+        public OutputStream getOutputStream(URI path) throws IOException  {
+            logger.error("CacheStoreSingleDitaFile: getOutputStream " + path.toString());
+            assert false;
+            flushSingleDocThrowIoXcpt(path);
+            return fallbackStore.getOutputStream(path);
+        }
+
+        /* URIResolver */
+        public Source resolve(String href, String base) throws TransformerException {
+            logger.error("CacheStoreSingleDitaFile: resolve href:" + href + " base:" + base);
+            assert false;
+            return fallbackStore.resolve(href, base);
+        }
+
+    }
+    /* VBox -- END */
 }
