+    /** 
+     * Checks whether all the topics in the map refers to the same file.
+     *  
+     * This is a scenario when producing a single HTML document out of a ditamap, 
+     * and it could get very expensive to read+write the whole single.dita document 
+     * for each topic when there are many many topics (986 topics - 3-4 min). 
+     *  
+     * @param   mapSet  The map to examine.
+     * @returns Name of the target file URI if it's the same for all topics, null if 
+     *        it differs.
+     */
+    private URI getSameTopicTargetFileName(final Map<URI, Map<String, Element>> mapSet) {
+        int numTopics = 0;
+        URI prevTargetFileName = null;
+        for (final Entry<URI, Map<String, Element>> entry : mapSet.entrySet()) {
+            final URI key = stripFragment(entry.getKey());
+            final FileInfo fi = job.getFileInfo(key);
+            if (fi != null && (fi.format == null || fi.format.equals(ATTR_FORMAT_VALUE_DITA))) {
+                final URI targetFileName = job.tempDirURI.resolve(fi.uri);
+                if (prevTargetFileName == null) {
+                    prevTargetFileName = targetFileName;
+                } else if (!targetFileName.equals(prevTargetFileName)) {
+                    return null;
+                }
+                numTopics += 1;
+            }
+        }
+        return numTopics > 1 ? prevTargetFileName : null;
+    }
