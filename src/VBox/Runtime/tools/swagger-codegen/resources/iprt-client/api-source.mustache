int {{classname}}::setOciReqSignKey(RTCRKEY a_hKey, const char *a_pszKeyId, size_t a_cchKeyId /*= RTSTR_MAX*/) RT_NOEXCEPT
{
    /*
     * Drop any previous key.
     */
    if (m_hKey != NIL_RTCRKEY)
    {
        uint32_t cRefs = RTCrKeyRelease(m_hKey);
        AssertRC(cRefs != UINT32_MAX); NOREF(cRefs);
        m_hKey = NIL_RTCRKEY;
    }

    /*
     * Copy string key ID and if that works out, retain a reference to the key.
     */
    int rc = m_strKeyId.assignNoThrow(a_pszKeyId, a_cchKeyId);
    if (RT_SUCCESS(rc) && a_hKey != NIL_RTCRKEY)
    {
        uint32_t cRefs = RTCrKeyRetain(a_hKey);
        AssertReturn(cRefs != UINT32_MAX, VERR_INVALID_HANDLE);
        m_hKey = a_hKey;
    }
    return rc;
}


int {{classname}}::setOciReqSignKey(RTCRKEY a_hKey, RTCString const &a_rstrKeyId) RT_NOEXCEPT
{
    return setOciReqSignKey(a_hKey, a_rstrKeyId.c_str(), a_rstrKeyId.length());
}

