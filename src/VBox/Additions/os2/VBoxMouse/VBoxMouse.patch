+
 CSEG    SEGMENT   WORD  PUBLIC  USE16 'CODE'
@@ -653,2 +658,87 @@
 
+ifdef VBOXMOUSE
+;;
+; Just a far call thunk - 16-bit is sooo fun.
+public VBoxInitComplete
+VBoxInitComplete PROC FAR
+       extrn    _VBoxAttachToVBoxGuest: near
+       ;
+       ; I'm going a bit overboard saving/restoring here...
+       ;
+       pushad
+       push     ds
+       push     es
+       push     fs
+       push     gs
+       mov      ax, seg APMDD
+       mov      es, ax
+       mov      ds, ax
+
+       call     _VBoxAttachToVBoxGuest
+
+       pop      gs
+       pop      fs
+       pop      es
+       pop      ds
+       popad
+       retf
+VBoxInitComplete ENDP
+
+;; USHORT __cdecl Call_KbdDI(int func,char __far  *buffer)
+;
+; Seems to be a little bit of confusion as to whether
+; who is cleaning up the stack, or at least if Watcom is
+; involed. So, I just play safe here and don't clean
+; up anything.
+;
+public _Call_KbdDI
+extrn _kbd_idc_entry:far
+_Call_KbdDI PROC NEAR
+        push    ebp
+        mov     ebp, esp
+        push    esi
+        push    edi
+        push    ds
+        push    es
+
+        ;
+        ; Connect?
+        ;
+        mov     ax, [_KbdDI_Handle]
+        cmp     ax, 0ffffh
+        jne     ckdi_1
+
+        push    0
+        lea     ax, [_kbd_idc_entry]
+        push    ax
+        push    ds
+        push    cs
+        call dword ptr [_KbdDI_Entry]
+        mov     [_KbdDI_Handle], ax
+
+        ;
+        ; Push the request.
+        ;
+ckdi_1:
+        mov     si, [bp + 6]            ; func
+        push    si
+;        mov     edi, [bp + 8]           ; buffer
+;        push    edi
+        les     di, [bp + 8]            ; buffer
+        push    di
+        push    es
+        push    ax                      ; kdbDI_Handle
+        call dword ptr ds:[_KbdDI_Entry]
+
+        lea     sp, [bp - 0ch]
+        pop     ds
+        pop     es
+        pop     esi
+        pop     edi
+        pop     ebp
+        ret
+_Call_KbdDI ENDP
+
+endif ; VBOXMOUSE
+
 
