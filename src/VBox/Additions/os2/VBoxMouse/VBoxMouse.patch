+                          if ( dwheel >= 128 ) {
+                                        KbdEvent(2, (PSZ)&scancodes[1]);
+                          }
+                 }
+        }
+
+        POP_STACK();
+#endif
+
+        // save our stack and call ASM function to process the packet
+        _asm
+        {
+           push ss
+           push bp
+           push sp
+           call Process_Absolute
+           pop sp
+           pop bp
+           pop ss
+        }
+
+        return;
+}
