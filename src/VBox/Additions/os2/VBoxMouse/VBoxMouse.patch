+        dwheel = MDAbs->wheel;
+
+        // put data into global structure for absolute positions
+        Int_Packet.X_Pos = MDAbs->positionX;
+        Int_Packet.Y_Pos = MDAbs->positionY;
+        Int_Packet.X_Size = MDAbs->resolutionX;
+        Int_Packet.Y_Size = MDAbs->resolutionY;
+        Int_Packet.Event = MDAbs->deviceStatus;
+
