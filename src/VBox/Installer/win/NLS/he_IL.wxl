    <String Id="Error1409" Value="לא ניתן לקרוא את פרטי האבטחה למפתח [2]. {{ שגיאת מערכת [3].}}  נא לוודא שהרשאות הגישה שלך מספיקות, או ליצור קשר עם התמיכה הטכנית שלך." />
    <String Id="Error1410" Value="לא ניתן להגדיל את מרחב רישום המערכת הזמין. דרושים [2] ק״ב של מקום פנוי לצורך התקנת היישום הזה." />
    <String Id="Error1500" Value="מתקיימת עוד התקנה במקביל. יש להשלים את ההתקנה בטרם בחירה להמשיך עם זאת." />
    <String Id="Error1501" Value="שגיאה בגישה לנתונים מאובטחים. נא לוודא שמתקין Windows מוגדר כראוי ולנסות להתקין שוב." />
    <String Id="Error1502" Value="המשתמש ‚[2]’ התחיל להתקין את המוצר ‚[3]’ בעבר. המשתמש הזה יצטרך להריץ את ההתקנה הזאת שוב לפני שיוכל להשתמש במוצר הזה. ההתקנה הנוכחית שלך תמשיך כעת." />
    <String Id="Error1503" Value="המשתמש ‚[2]’ התחיל להתקין את המוצר ‚[3]’ בעבר. המשתמש הזה יצטרך להריץ את ההתקנה הזאת שוב לפני שיוכל להשתמש במוצר הזה." />
    <String Id="Error1601" Value="נגמר המקום בכונן -- כרך: ‚[2]’; הנפח הדרוש: [3] ק״ב; הנפח הפנוי: [4] ק״ב. יש לפנות מקום בכונן ולנסות שוב." />
    <String Id="Error1602" Value="לבטל?" />
    <String Id="Error1603" Value="הקובץ [2][3] מוזחק בשימוש{ על ידי התהליך הבא: שם: [4], מזהה: [5], כותרת החלון: ‚[6]’}. יש לסגור את היישום הזה ולנסות שוב." />
    <String Id="Error1604" Value="המוצר ‚[2]’ כבר מותקן, מה שמונע את התקנת המוצר הזה. שני המוצרים אינם תואמים זה לזה." />
    <String Id="Error1605" Value="אין מספיק מקום פנוי בכרך ‚[2]’ כדי להמשיך בהתקנה עם שחזור פעיל. [3] ק״ב דרושים, אך רק [4] ק״ב זמינים. יש ללחוץ על ״התעלמות” כדי להמשיך את ההתקנה ללא שמירת פרטי השחזור, לחיצה על „לנסות שוב” תבדוק את המקום הפנוי שוב, „ביטול” תסגור את תוכנית ההתקנה." />
    <String Id="Error1606" Value="לא ניתן לגשת למקום ברשת [2]." />
    <String Id="Error1607" Value="יש לסגור את היישומים הבאים בטרם המשך בהתקנה:" />
    <String Id="Error1608" Value="לא ניתן למצוא מוצרים תואמים מותקנים קודמים במכונה להתקנת המוצר הזה." />
    <String Id="Error1609" Value="אירעה שגיאה במהלך החלת הגדרות האבטחה. [2] זה לא משתמש או קבוצה תקינים. זאת יכולה להיות בעיה עם החבילה, או בעיה בהתחברות לבקר תחום (domain controller) ברשת. נא לבדוק שהחיבור שלך לרשת תקין וללחוץ על „לנסות שוב” או על ביטול כדי לסיים את ההתקנה. {{לא ניתן לאתר את מזהה האבטחה (SID) של המשתמש, שגיאת מערכת [3]}}" />
    <String Id="Error1701" Value="המפתח [2] אינו תקני. נא לוודא שמילאת את המפתח הנכון." />
    <String Id="Error1702" Value="תוכנית ההתקנה חייבת להפעיל את המערכת שלך מחדש בטרם המשך הגדרת [2]. יש ללחוץ על „כן” כדי להפעיל מחדש או על „לא” אם תכננת להפעיל את המערכת מחדש ידנית בהמשך." />
    <String Id="Error1703" Value="יש להפעיל את המחשב שלך מחדש כדי ששינויי ההגדרות שביצעת מול [2] יהיו בתוקף. יש ללחוץ על „כן” כדי להפעיל מחדש כעת או על „לא” אם תכננת להפעיל את המערכת מחדש ידנית בהמשך." />
    <String Id="Error1704" Value="ההתקנה של [2] מושהית כרגע. יש להחזיר לאחור את השינויים שבוצעו על ידי ההתקנה כדי להמשיך. להחזיר את השינויים האלה לאחור?" />
    <String Id="Error1705" Value="התקנה קודמת של המוצר הזה מתרחשת ברקע. יש להחזיר לאחור את השינויים שבוצעו על ידי ההתקנה כדי להמשיך. להחזיר את השינויים האלה לאחור?" />
    <String Id="Error1706" Value="לא ניתן למצוא חבילת התקנה למוצר [2]. כדאי לנסות להתקין שוב באמצעות עותק תקף של חבילת ההתקנה ‚[3]’." />
    <String Id="Error1707" Value="ההתקנה הולשמה בהצלחה." />
    <String Id="Error1708" Value="ההתקנה נכשלה." />
    <String Id="Error1709" Value="מוצר: [2] -- [3]" />
    <String Id="Error1710" Value="אפשר לשחזיר את המחשב שלך למצבו הקודם או להמשיך את ההתקנה בפעם אחרת. לשחזר?" />
    <String Id="Error1711" Value="אירעה שגיאה בכתיבת פרטי ההתקנה לכונן. כדאי לודא שיש מספיק נפח פנוי בכונן וללחוץ על „לנסות שוב” או על „ביטול” כדי לסיים את ההתקנה." />
    <String Id="Error1712" Value="קובץ אחד או יותר שנחוצים לשחזור המחשב שלך למצבו הקודם לא נמצאו. לא תהיה אפשרות לשחזר." />
    <String Id="Error1713" Value="[2] לא הצליח להתקין את אחד המוצרים שנחוצים לו. נא ליצור קשר עם קבוצת התמיכה הטכנית שלך. {{מחרוזת מערכת: [3].}}" />
    <String Id="Error1714" Value="לא ניתן להסיר את הגרסה הישנה יותר של [2]. נא ליצור קשר עם קבוצת התמיכה הטכנית שלך. {{מחרוזת מערכת [3].}}" />
    <String Id="Error1715" Value="[2] הותקן" />
    <String Id="Error1716" Value="[2] הוגדר" />
    <String Id="Error1717" Value="[2] הוסר" />
    <String Id="Error1718" Value="הקובץ [2] נדחה על ידי מדיניות החתימה הדיגיטלית." />
    <String Id="Error1719" Value="לא ניתן לגשת לשירות מתקין Windows. מצב כזה יכול לקרות אם Windows פועל במצב בטוח, או אם מתקין Windows לא מותקן כראוי. נא ליצור קשר עם גוף התמיכה שלך לקבלת סיוע." />
    <String Id="Error1720" Value="יש בעיה עם חבילת מתקין ה־Windows הזאת. לא ניתן להריץ סקריפט שנחוץ להשלמת ההתקנה. נא ליצור קשר עם גוף התמיכה שלך או עם ספק החבילה שלך. {{פעולה מותאמת [2] שגיאת סקריפט [3], [4]: [5] שורה [6], עמודה [7], [8] }}" />
    <String Id="Error1721" Value="יש בעיה עם חבילת מתקין ה־Windows הזאת. לא ניתן להריץ תוכנית שחיונית להשלמת ההתקנה הזאת. נא ליצור קשר עם גוף התמיכה שלך או עם ספק החבילה שלך. {{פעולה: [2], מקום: [3], פקודה: [4] }}" />
    <String Id="Error1722" Value="יש בעיה עם חבילת מתקין ה־Windows הזאת. הרצה של תוכנית כחלק מההתקנה הזאת לא הסתיימה כצפוי. נא ליצור קשר עם גוף התמיכה שלך או עם ספק החבילה שלך. {{פעולה [2], מקום: [3], פקודה: [4] }}" />
    <String Id="Error1723" Value="יש בעיה עם חבילת מתקין ה־Windows הזאת. לא ניתן להריץ DLL שנחוץ להשלמת ההתקנה הזאת. נא ליצור קשר עם גוף התמיכה שלך או עם ספק החבילה שלך. {{פעולה [2], רשומה: [3], ספרייה: [4] }}" />
    <String Id="Error1724" Value="ההסרה הושלמה בהצלחה." />
    <String Id="Error1725" Value="ההסרה נכשלה." />
    <String Id="Error1726" Value="הפרסום הושלם בהצלחה." />
    <String Id="Error1727" Value="הפרסום נכשל." />
    <String Id="Error1728" Value="ההגדרה הושלמה בהצלחה." />
    <String Id="Error1729" Value="ההגדרה נכשלה." />
    <String Id="Error1730" Value="רק מנהלים יכולים להסיר את היישום הזה. כדי להסיר את היישום הזה, אפשר להיכנס עם חשבון ניהול או ליצור קשר עם קבוצת התמיכה הטכנית שלך לקבלת סיוע." />
    <String Id="Error1801" Value="הנתיב [2] שגוי. נא לציין נתיב תקף." />
    <String Id="Error1802" Value="הזיכרון נגמר. יש לכבות יישומים אחרים לפני ביצוע ניסיון חוזר." />
    <String Id="Error1803" Value="אין אמצעי אחסון בכונן [2]. נא להכניס אחד כזה וללחוץ על „לנסות שוב”, או ללחוץ על „ביטול” כדי לחזור לכרך הקודם שנבחר." />
    <String Id="Error1804" Value="אין אמצעי אחסון בכונן [2]. נא להכניס אחד וללחוץ על „לנסות שוב” או ללחוץ על „ביטול” כדי לחזור לחלונית העיון ולבחור בכרך אחר." />
    <String Id="Error1805" Value="התיקייה [2] לא קיימת. נא למלא נתיב לתיקייה קיימת." />
    <String Id="Error1806" Value="אין לך את ההרשאות המתאימות לקרוא את התיקייה הזאת." />
    <String Id="Error1807" Value="לא ניתן לקבוע תיקיית יעד תקינה להתקנה." />
    <String Id="Error1901" Value="שגיאה בניסיון לקרוא ממסד נתוני התקנת המקור: [2]." />
    <String Id="Error1902" Value="תזמון פעולה להפעלה מחדש: שינוי השם של הקובץ [2] לשם [3]. יש להפעיל מחדש כדי להשלים את הפעולה." />
    <String Id="Error1903" Value="תזמון פעולה להפעלה מחדש: מחיקת הקובץ [2]. יש להפעיל מחדש כדי להשלים את הפעולה." />
    <String Id="Error1904" Value="רישום המודול [2] נכשל. HRESULT [3]. נא ליצור קשר עם גוף התמיכה שלך." />
    <String Id="Error1905" Value="ביטול רישום המודול [2] נכשל. HRESULT [3]. נא ליצור קשר עם גוף התמיכה שלך." />
    <String Id="Error1906" Value="אחסון התיקייה [2] במטמון נכשל. שגיאה: [3]. נא ליצור קשר עם גוף התמיכה שלך." />
    <String Id="Error1907" Value="לא ניתן לרשום את הגופן [2]. נא לוודא שיש לך מספיק הרשאות כדי להתקין גופנים, ושהמערכת תומכת בגופן הזה." />
    <String Id="Error1908" Value="לא ניתן לבטל את רישום הגופן [2]. נא לוודא שיש לך מספיק הרשאות כדי להסיר גופנים." />
    <String Id="Error1909" Value="לא ניתן ליצור את קיצור הדרך [2]. נא לוודא שתיקיית היעד קיימת ושיש לך גישה אליה." />
    <String Id="Error1910" Value="לא ניתן להסיר את קיצור הדרך [2]. נא לוודא שקובץ קיצור הדרך קיים ושיש לך גישה אליו." />
    <String Id="Error1911" Value="לא ניתן לרשום ספריית סוג לקובץ [2]. נא ליצור קשר עם גוף התמיכה שלך." />
    <String Id="Error1912" Value="לא ניתן לבטל רישום ספריית סוג לקובץ [2]. נא ליצור קשר עם גוף התמיכה שלך." />
    <String Id="Error1913" Value="לא ניתן לעדכן את קובץ ה־ini [2][3]. נא לוודא שהקובץ קיים ושיש לך גישה אליו." />
    <String Id="Error1914" Value="לא ניתן לתזמן החלפת הקובץ [2] בקובץ [3] עם ההפעלה מחדש. נא לוודא שיש לך הרשאה לכתוב לקובץ [3]." />
    <String Id="Error1915" Value="שגיאה בהסרת מנהל למנהלי התקנים של ODBC, שגיאת ODBC [2]: [3]. נא ליצור קשר עם גוף התמיכה שלך." />
    <String Id="Error1916" Value="שגיאה בהתקנת מנהל למנהלי התקנים של ODBC, שגיאת ODBC [2]: [3]. נא ליצור קשר עם גוף התמיכה שלך." />
    <String Id="Error1917" Value="שגיאה בהסרת מנהל התקן ODBC: [4], שגיאת ODBC [2]: [3]. נא לוודא שיש לך הרשאות מספיקות להסרת מנהלי התקנים של ODBC." />
    <String Id="Error1918" Value="שגיאה בהתקנת מנהל התקן ODBC: [4], שגיאת ODBC [2]: [3]. נא לוודא שהקובץ [4] קיים ושיש לך גישה אליו." />
    <String Id="Error1919" Value="שגיאה בגדרת מקור נתוני ODBC: [4], שגיאת ODBC [2]: [3]. נא לוודא שהקובץ [4] קיים ושיש לך גישה אליו." />
    <String Id="Error1920" Value="הפעלת השירות ‚[2]’ ([3]) נכשלה. נא לוודא שיש לך מספיק הרשאות להפעיל שירותי מערכת." />
    <String Id="Error1921" Value="לא ניתן לעצור את השירות ‚[2]’ ([3]). נא לוודא שיש לך מספיק הרשאות לעצור שירותי מערכת." />
    <String Id="Error1922" Value="לא ניתן למחוק את השירות ‚[2]’ ([3]). נא לוודא שיש לך מספיק הרשאות להסיר שירותי מערכת." />
    <String Id="Error1923" Value="לא ניתן להתקין את השירות ‚[2]’ ([3]). נא לוודא שיש לך מספיק הרשאות להתקין שירותי מערכת." />
    <String Id="Error1924" Value="לא ניתן לעדכן את משתנה הסביבה ‚[2]’. נא לוודא שיש לך מספיק הרשאות לשנות משתנים סביבתיים." />
    <String Id="Error1925" Value="אין לך מספיק הרשאות להשלים את ההתקנה הזאת לכל המשתמשים במכונה. יש להיכנס למערכת עם חשבון ניהול ואז לנסות להתקין מחדש." />
    <String Id="Error1926" Value="לא ניתן להגדיר אבטחת קובץ לקובץ ‚[3]’. שגיאה: [2]. נא לוודא שיש לך מספיק הרשאות לשנות את הרשאות האבטחה של הקובץ הזה.." />
    <String Id="Error1927" Value="Component Services/שירותי רכיבים (COM+ 1.0) לא מותקנים במחשב הזה. ההתקנה הזאת דורשת ש־Component Services/שירותי מערכת יהיו מותקנים כדי שתושלם בהצלחה. Component Services זמינים ב־Windows 2000." />
    <String Id="Error1928" Value="שגיאה ברישום יישום COM+‎. נא ליצור קשר עם גוף התמיכה שלך למידע נוסף." />
    <String Id="Error1929" Value="שגיאה בביטול רישום COM+‎. נא ליצור קשר עם גוף התמיכה שלך למידע נוסף." />
    <String Id="Error1930" Value="לא ניתן לשנות את תיאור השירות ‚[2]’ ([3])." />
    <String Id="Error1931" Value="שירות המתקין של Windows לא יכול לעדכן את קובץ המערכת [2] כיוון שהקובץ מוגן על ידי Windows. יכול להיות שצריך לעדכן את מערכת ההפעלה שלך כדי שהתוכנית הזאת תעבוד כראוי. {{גרסת חבילה: [3], גרסת מערכת הפעלה מוגנת: [4]}}" />
    <String Id="Error1932" Value="שירות המתקין של Windows לא יכול לעדכן את קובץ ה־Windows המוגן [2]. {{גרסת חבילה: [3], גרסת מערכת הפעלה מוגנת: [4], שגיאת הגנת קובצי מערכת (SFP): [5]}}" />
    <String Id="Error1933" Value="שירות מתקין Windows לא יכול לעדכן קובץ Windows מוגן אחד או יותר. {{מחרוזת הגנת קובצי מערכת (SFP): [2]. רשימת הקבצים המוגנים:\r\n[3]}}" />
