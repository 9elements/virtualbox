#--svn-sync-process-export none

# Suffix Mappings.
/*.i:       --treat-as .inc
/*.r:       --treat-as .inc
/*makefile: --treat-as Makefile
/*.mak:     --treat-as Makefile
/*.rom:     --treat-as binary
/*.patch:   --treat-as plaintext --no-convert-tabs --no-strip-trailing-blanks --strip-no-trailing-lines --dont-set-svn-keywords

# Mark source files as external and stuff...
/*.asm:     --svn-sync-process-export none --external-copyright --no-convert-tabs --no-strip-trailing-blanks
/*.c:       --svn-sync-process-export none --external-copyright --no-convert-tabs --no-strip-trailing-blanks
/*.h:       --svn-sync-process-export none --external-copyright --no-convert-tabs --no-strip-trailing-blanks --dont-set-svn-keywords --no-fix-header-guards
/*.inc:     --svn-sync-process-export none --external-copyright --no-convert-tabs --no-strip-trailing-blanks
/*.i:       --svn-sync-process-export none --external-copyright --no-convert-tabs --no-strip-trailing-blanks --strip-no-trailing-lines
/*.r:       --svn-sync-process-export none --external-copyright --no-convert-tabs --no-strip-trailing-blanks --strip-no-trailing-lines

# ... then undo it for the ones that are ours.
/client/pcnet/*:        --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks
/client/pcnet/*.h:      --svn-sync-process-export all --set-svn-keywords --fix-header-guards
/include/debug.h:       --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks --set-svn-keywords --fix-header-guards
/include/nic_api.h:     --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks --set-svn-keywords --fix-header-guards
/include/segdefs.inc:   --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks --set-svn-keywords --fix-header-guards
/client/pcnet/*:        --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks
/romlib/dputc.c:        --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks
/romlib/dputh1.c:       --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks
/romlib/dputh2.c:       --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks
/romlib/dputh4.c:       --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks
/romlib/dputh8.c:       --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks
/romlib/dputip.c:       --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks
/romlib/dputs.c:        --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks
/romlib/dputu16.c:      --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks
/romlib/dputu32.c:      --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks
/romlib/findclas.asm:   --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks
/romlib/finddev.asm:    --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks
/romlib/rdcfgb.asm:     --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks
/romlib/rdcfgd.asm:     --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks
/romlib/rdcfgw.asm:     --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks
/romlib/wrcfgb.asm:     --svn-sync-process-export all --no-external-copyright --convert-tabs --strip-trailing-blanks

