+/* Needs to match DevPcBios.cpp */
+#define NET_BOOT_DEVS       4
+
+_WCIRTLINK extern unsigned inp(unsigned __port);
+_WCIRTLINK extern unsigned outp(unsigned __port, unsigned __value);
+#pragma intrinsic(inp,inpw,outp,outpw)
+
+/* Read a byte from the second CMOS bank. */
+uint8_t cmos2_read(uint8_t offset)
+{
+    outp(0x72, offset);
+    return inp(0x73);
+}
+
+/* Read a byte from the second CMOS bank. */
+void cmos2_write(uint8_t offset, uint8_t val)
+{
+    outp(0x72, offset);
+    outp(0x73, val);
+}
+
+/* Find the next NIC to boot from. The next value is read from CMOS
+ * and written back to a different CMOS location for use by the UNDI
+ * driver. This is done because the PXE base code can't easily access
+ * the internals of the UNDI driver and vice versa.
+ */
+static int next_nic(int boot_nic_index)
+{
+    uint16_t    busdevfn;
+
+    /* Ensure an invalid index won't be used. */
+    if (boot_nic_index >= NET_BOOT_DEVS || boot_nic_index < 0)
+        return -1;
+
+    /* Read the next bus/dev/fn from second CMOS bank. See DevPcBios for
+     * CMOS layout information.
+     */
+    busdevfn  = cmos2_read(2 + boot_nic_index * 2);
+    busdevfn |= cmos2_read(3 + boot_nic_index * 2) << 8;
+
+    /* Write the bus/dev/fn back to the CMOS for the UNDI driver. */
+    cmos2_write(0, busdevfn & 0xff);
+    cmos2_write(1, busdevfn >> 8);
+
+    ++boot_nic_index;
+
+    /* Don't try again if this was the last device. */
+    if (boot_nic_index >= NET_BOOT_DEVS)
+        return -1;
+
+    /* If this was the "legacy" (lowest prio) device, don't try either. */
+    if (busdevfn == 0 || busdevfn == 0xffff)
+        return -1;
+
+    /* Read the next bus/dev/fn */
+    busdevfn  = cmos2_read(2 + boot_nic_index * 2);
+    busdevfn |= cmos2_read(3 + boot_nic_index * 2) << 8;
+
+    /* The default device is only allowed as the first entry. */
+    if (busdevfn == 0xffff)
+        return -1;
+
+    return boot_nic_index;
+}
+
